{
  "name": "@getpaseo/provider-omp",
  "version": "0.1.107",
  "private": true,
  "description": "Paseo Oh My Pi provider",
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "node ../../scripts/clean-package-dist.mjs",
    "build": "tsc -p tsconfig.json --incremental false",
    "build:clean": "npm run clean && npm run build",
    "prepack": "npm run build:clean",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@getpaseo/protocol": "0.1.107",
    "@getpaseo/provider-sdk": "0.1.107",
    "pino": "^10.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "typescript": "^5.2.2",
    "vitest": "^4.1.6"
  }
}
